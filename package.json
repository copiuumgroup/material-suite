{
  "name": "material-audio-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "Material Audio Mastery Studio",
  "author": "copiuum group",
  "scripts": {
    "dev": "vite",
    "bump": "node scripts/bump-version.js",
    "build": "npm run bump && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "package": "npm run bump && npm run build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@material/web": "^2.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.copiuum.materialstudio",
    "productName": "Material Suite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "icon": "build/icon.png",
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable"
      ],
      "artifactName": "Material Suite-dev-a9pfs.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Material Suite",
      "artifactName": "Material Suite-dev-a9pfs.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "shortcutName": "Material Studio",
      "artifactName": "Material Suite-dev-a9pfs.${ext}"
    }
  }
}